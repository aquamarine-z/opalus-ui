{
  "name": "opalus-ui",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:radix-fixture": "astro build --config e2e/radix/astro.config.mjs",
    "preview": "astro preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:radix": "playwright test --config playwright.radix.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:radix": "tsc -p tsconfig.radix.json --noEmit",
    "check": "pnpm typecheck && pnpm typecheck:radix && pnpm test && pnpm test:e2e && pnpm test:e2e:radix && pnpm build && pnpm registry:check",
    "astro": "astro",
    "registry:validate": "shadcn registry validate registry.json",
    "registry:build": "shadcn build registry.json",
    "registry:check": "node scripts/check-registry.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/starlight": "^0.41.3",
    "@base-ui/react": "1.6.0",
    "@catppuccin/starlight": "^2.1.0",
    "@ebay/nice-modal-react": "^1.2.13",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-syntax-highlighter": "^16.1.1",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "jsdom": "^29.1.1",
    "radix-ui": "1.6.2",
    "shadcn": "4.13.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vaul": "1.1.2",
    "vitest": "^4.1.10"
  }
}
